// Prisma schema for セイキューン!
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────── Client (顧客) ─────────
model Client {
  id                        String   @id @default(uuid())
  name                      String
  honorific                 String   @default("御中")
  postalCode                String?  @map("postal_code")
  prefecture                String?
  city                      String?
  building                  String?
  tel                       String?
  contacts                  Json?    // [{ name: string; email: string }]
  defaultPaymentTerms       String?  @map("default_payment_terms")
  feeBearer                 String   @default("client") @map("fee_bearer") // client | self
  sendMethod                String   @default("post") @map("send_method")  // mail | post | mail_and_post
  bankAccountId             String?  @map("bank_account_id")
  clientNumber              String?  @map("client_number")
  corporateNumber           String?  @map("corporate_number")
  invoiceEligibility        String   @default("unset") @map("invoice_eligibility") // unset | eligible | not_eligible
  invoiceRegistrationNumber String?  @map("invoice_registration_number")
  notes                     String?
  tags                      String[] @default([])
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  projects                  Project[]

  @@map("clients")
}

// ───────── Project (案件) ─────────
model Project {
  id                  String   @id @default(uuid())
  projectNumber       String   @unique @map("project_number")
  clientId            String   @map("client_id")
  name                String
  orderStatus         String   @default("estimating") @map("order_status") // estimating | ordered | lost
  invoiceTiming       String   @default("single") @map("invoice_timing")   // single | recurring | split
  invoiceDate         String?  @map("invoice_date")
  splitInvoiceDates   String[] @default([]) @map("split_invoice_dates")
  recurringInterval   String?  @map("recurring_interval") // weekly | monthly | bimonthly | quarterly | yearly
  recurringNotify     Boolean? @map("recurring_notify")
  recurringAutoRenew  Boolean? @map("recurring_auto_renew")
  deliveryDate        String?  @map("delivery_date")
  syncDeliveryDate    Boolean? @map("sync_delivery_date")
  paymentTerms        String?  @map("payment_terms")
  paymentMethod       String   @default("bank_transfer") @map("payment_method")
  progress            String   @default("not_started")
  rounding            String   @default("floor")
  internalMemo        String?  @map("internal_memo")
  estimateAmount      Int      @default(0) @map("estimate_amount")
  invoiceAmount       Int      @default(0) @map("invoice_amount")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents           Document[]
  branches            EstimateBranch[]

  @@map("projects")
}

// ───────── Document (見積/請求/etc 書類) ─────────
model Document {
  id              String   @id @default(uuid())
  projectId       String   @map("project_id")
  type            String   // estimate | purchase-order | delivery | invoice | receipt | cover-letter
  documentNumber  String   @map("document_number")
  subject         String   @default("")
  primaryDate     String?  @map("primary_date")
  secondaryDate   String?  @map("secondary_date")
  notes           String?
  status          String   @default("draft") // draft | issued
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items           DocumentItem[]

  @@unique([projectId, type])
  @@map("documents")
}

model DocumentItem {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  rowType     String   @default("normal") @map("row_type") // normal | heading | subtotal
  name        String   @default("")
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Int      @default(0) @map("unit_price")
  taxRate     Int      @default(10) @map("tax_rate") // 0 | 8 | 10
  notes       String?
  sortOrder   Int      @map("sort_order")

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_items")
}

// ───────── EstimateBranch (見積の別パターン) ─────────
model EstimateBranch {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  name          String
  items         Json     // DocumentItem[] (snapshot)
  notes         String?
  subject       String?
  primaryDate   String?  @map("primary_date")
  secondaryDate String?  @map("secondary_date")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("estimate_branches")
}

// ───────── DocumentTemplate (書類テンプレート) ─────────
model DocumentTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String   // estimate | invoice | etc
  items     Json     // DocumentItem[] (snapshot)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("document_templates")
}
